{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Europe/Amsterdam",
  "schedule": ["before 3am on Monday"],
  "prConcurrentLimit": 10,
  "minimumReleaseAge": "3 days",
  "prCreation": "not-pending",
  "updateNotScheduled": false,
  "packageRules": [
    {
      "description": "Group all updates by sample-app subfolder",
      "matchPaths": ["sample-apps/**"],
      "matchFileNames": ["sample-apps/**/*"],
      "additionalBranchPrefix": "{{#if isGroup }}{{ else }}{{packageFileDir}}/{{/if}}",
      "commitMessageSuffix": "{{#if isGroup }}{{ else }} ({{packageFileDir}}){{/if}}"
    }
  ]
}
